# =============================================================================
# BrightPath Academy FAQ Chatbot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# NEVER commit your .env file to GitHub.
# This .env.example file is safe to commit — it contains no real credentials.
# =============================================================================


# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Used for LLM text generation (gemini-2.5-flash-lite)

GOOGLE_API_KEY=your_google_api_key_here


# ── AstraDB (Datastax) ────────────────────────────────────────────────────────
# Get these from: https://astra.datastax.com
# Steps: Create database → Generate Application Token → Copy API Endpoint
#
# API Endpoint format: https://xxxx-region.apps.astra.datastax.com

ASTRA_DB_API_ENDPOINT=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-us-east1.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The keyspace inside your AstraDB database.
# Default is 'default_keyspace' unless you created a custom one.
ASTRA_DB_NAMESPACE=default_keyspace

# The collection (table) where your document vectors are stored.
# Created automatically when you run the ingestion script.
ASTRA_DB_COLLECTION=brightpath_rag


# ── Embeddings ────────────────────────────────────────────────────────────────
# The sentence-transformers model used to embed document chunks and queries.
# Runs locally — no API key required.
# Change only if you want to use a different embedding model.

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ── Optional: HuggingFace ─────────────────────────────────────────────────────
# Only needed if you hit HuggingFace API rate limits when downloading
# the embedding model. Get a free token at: https://huggingface.co/settings/tokens

# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
