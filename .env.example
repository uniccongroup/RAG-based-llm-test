# Application Settings
APP_NAME=UNICCON RAG Chatbot
DEBUG=False
LOG_LEVEL=INFO

# LLM Configuration
# Using Hugging Face model (free and open-source)
LLM_PROVIDER=huggingface  # Options: huggingface, openai, cohere
HF_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
HF_API_TOKEN=hf_your_token_here

# For OpenAI (optional)
OPENAI_API_KEY=sk-your_openai_key_here

# For Cohere (optional)
COHERE_API_KEY=your_cohere_key_here

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=3
SIMILARITY_THRESHOLD=0.05

# Server Configuration
HOST=0.0.0.0
PORT=8000
